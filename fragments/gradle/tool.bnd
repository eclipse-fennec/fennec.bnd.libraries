# tool.bnd — controls how this fragment's files are copied into the target workspace.
# The -tool instruction is a SELECT matched against file PATHS (not names).
# Attributes: skip, append, exec, preprocess (alias: macro), delete.
-tool: \
	.*;tool.bnd;readme.md;skip=true, \
	gradle.properties;macro=true;append=true, \
	gradlew;exec=true, \
	*
